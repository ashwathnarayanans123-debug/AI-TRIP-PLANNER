# AI Trip Planner Agent — Backend environment variables
# Copy to .env and fill in real values.

# ---------------------------------------------------------------------------
# AI Providers — at least one required for live AI planning
# ---------------------------------------------------------------------------

# Preferred free AI provider (Groq — OpenAI-compatible, free tier available)
# Get key at: https://console.groq.com/
GROQ_API_KEY=gsk_your_groq_key
GROQ_MODEL=llama-3.3-70b-versatile

# Optional OpenAI fallback (used only if GROQ_API_KEY is missing)
# Get key at: https://platform.openai.com/
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# Weather
# ---------------------------------------------------------------------------

# OpenWeather — current + 5-day forecast (free tier works)
# Falls back to Open-Meteo (no key needed) if missing or invalid
# Get key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your-openweather-key

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# SQLite (default, local dev):
# DATABASE_URL=sqlite:///./trip_planner.db

# PostgreSQL (Render/production) — paste the Internal Database URL from Render:
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---------------------------------------------------------------------------
# Rate limiting
# ---------------------------------------------------------------------------

# Max AI plan-trip requests per minute per IP (slowapi format)
PLAN_TRIP_RATE_LIMIT=10/minute

# ---------------------------------------------------------------------------
# Debugging
# ---------------------------------------------------------------------------

# Set to true to echo SQL queries to the log (dev only)
SQL_ECHO=false
